# Spencer OS — environment variable template
# Copy to .env and fill in your values.

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPA_URL=https://your-project.supabase.co
SUPA_KEY=your-supabase-anon-key

# ── Telegram ──────────────────────────────────────────────────────────────────
TG_TOKEN=your-telegram-bot-token
# Your personal Telegram chat ID — get it by messaging @userinfobot on Telegram
# Required for daily_briefing.py to send morning briefings to you
TG_CHAT_ID=your-telegram-chat-id

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_KEY=sk-proj-your-openai-key

# ── Hevy (optional) ───────────────────────────────────────────────────────────
# Get your API key from hevy.app → Settings → API
# Can also be entered directly in the Workouts module UI
HEVY_KEY=your-hevy-api-key

# ── Plaid (optional) ──────────────────────────────────────────────────────────
# Sign up at dashboard.plaid.com → create app → get client_id + secret
# Use PLAID_ENV=sandbox for testing with test credentials (no real bank)
# Use PLAID_ENV=development for real bank connections (free up to 100 items)
# Use PLAID_ENV=production when deploying publicly
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8765
# Set to your public domain when deploying, e.g. https://spencer-os.fly.dev
# Or your custom domain after running: flyctl certs add yourdomain.com
BASE_URL=http://localhost:8765
