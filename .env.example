# Spencer OS — environment variable template
# Copy to .env and fill in your values.

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPA_URL=https://your-project.supabase.co
SUPA_KEY=your-supabase-anon-key

# ── Telegram ──────────────────────────────────────────────────────────────────
TG_TOKEN=your-telegram-bot-token
# Your personal Telegram chat ID — get it by messaging @userinfobot on Telegram
# Required for daily_briefing.py to send morning briefings to you
TG_CHAT_ID=your-telegram-chat-id

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_KEY=sk-proj-your-openai-key

# ── Hevy (optional) ───────────────────────────────────────────────────────────
# Get your API key from hevy.app → Settings → API
# Can also be entered directly in the Workouts module UI
HEVY_KEY=your-hevy-api-key

# ── Plaid (optional) ──────────────────────────────────────────────────────────
# Sign up at dashboard.plaid.com → create app → get client_id + secret
# Use PLAID_ENV=sandbox for testing with test credentials (no real bank)
# Use PLAID_ENV=development for real bank connections (free up to 100 items)
# Use PLAID_ENV=production when deploying publicly
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# ── Google Calendar (server-side OAuth) ──────────────────────────────────────
# 1. console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# 2. Add  https://spencer-os.fly.dev/google/callback  as an Authorized redirect URI
# 3. Enable the Google Calendar API in APIs & Services → Library
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Override only if using a custom domain
# GOOGLE_REDIRECT=https://spencer-os.fly.dev/google/callback

# ── WHOOP (optional — also accepts credentials from the UI) ───────────────────
# Setting these as secrets lets the server refresh tokens without client involvement.
# Can also leave empty; server falls back to credentials stored in Supabase kv_store.
WHOOP_CLIENT_ID=your-whoop-client-id
WHOOP_CLIENT_SECRET=your-whoop-client-secret

# ── Web Push / VAPID ─────────────────────────────────────────────────────────
# Generated once with: openssl genpkey -algorithm EC -pkeyopt ec_paramgen_curve:P-256
# See README for generation steps. NEVER regenerate — existing browser subs will break.
VAPID_PUBLIC_KEY=BDwPZXAgk8U1Ndf-6S7pAr-_UEpeJJIzGAtxa_eFfnnfyARlwm9xfLs8mtpaf8gME_lUcDCfB8P6wXws_pOqWZo
VAPID_PRIVATE_KEY=MIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQgqytc3vAwFMJLagy5lYRm3JYcuBml8j9AHQViODhcCPqhRANCAAQ8D2VwIJPFNTXX_uku6QK_v1BKXiSSMxgLcWv3hX5538gEZcJvcXy7PJraWn_IDBP5VHAwnwfD-sF8LP6Tqlma
# Must be a mailto: or https: URL
VAPID_SUBJECT=mailto:admin@spencer-os.fly.dev

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8765
# Set to your public domain when deploying, e.g. https://spencer-os.fly.dev
# Or your custom domain after running: flyctl certs add yourdomain.com
BASE_URL=http://localhost:8765
